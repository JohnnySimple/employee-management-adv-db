generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int       @id @default(autoincrement())
  name         String    @unique
  email        String    @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  employeeId   Int?      @unique
  isActive     Boolean   @default(true)
  passwordHash String
  role         Role      @default(EMPLOYEE)
  employee     Employee? @relation(fields: [employeeId], references: [employeeId])
}

model Employee {
  employeeId     Int               @id @default(autoincrement())
  firstName      String
  lastName       String
  dob            DateTime
  hireDate       DateTime
  email          String            @unique
  phone          String?
  jobStatus      String
  deptId         Int
  jobTitleId     Int
  attendance     Attendance[]
  manages        Department[]      @relation("DepartmentManager")
  department     Department        @relation(fields: [deptId], references: [deptId])
  jobTitle       JobTitle          @relation(fields: [jobTitleId], references: [jobTitleId])
  employeeLeaves EmployeeLeave[]
  projects       ProjectAssigned[]
  salaries       Salary[]
  user           User?
}

model Department {
  deptId    Int        @id @default(autoincrement())
  deptName  String
  managerId Int?
  manager   Employee?  @relation("DepartmentManager", fields: [managerId], references: [employeeId])
  employees Employee[]
}

model JobTitle {
  jobTitleId Int        @id @default(autoincrement())
  titleName  String
  payRate    Float
  employees  Employee[]
}

model Salary {
  salaryId   Int      @id @default(autoincrement())
  employeeId Int
  salaryDate DateTime
  amount     Float
  employee   Employee @relation(fields: [employeeId], references: [employeeId])
}

model Attendance {
  attendanceId  Int      @id @default(autoincrement())
  employeeId    Int
  workDate      DateTime
  timeIn        DateTime
  timeOut       DateTime?
  hoursWorked   Float?
  overtimeHours Float?
  employee      Employee @relation(fields: [employeeId], references: [employeeId])
}

model Project {
  projectId   Int               @id @default(autoincrement())
  projectName String
  startDate   DateTime
  endDate     DateTime
  location    String
  status      ProjectStatus     @default(ACTIVE)
  assigned    ProjectAssigned[]
}

model ProjectAssigned {
  assignId     Int      @id @default(autoincrement())
  employeeId   Int
  projectId    Int
  assignedDate DateTime
  employee     Employee @relation(fields: [employeeId], references: [employeeId])
  project      Project  @relation(fields: [projectId], references: [projectId])
}

model Leave {
  leaveId        Int             @id @default(autoincrement())
  leaveType      String
  employeeLeaves EmployeeLeave[]
}

model EmployeeLeave {
  employeeLeaveId Int         @id @default(autoincrement())
  employeeId      Int
  leaveId         Int
  totalLeaveHours Float
  totalRemaining  Float
  status          String      @default("Pending")
  employee        Employee    @relation(fields: [employeeId], references: [employeeId])
  leave           Leave       @relation(fields: [leaveId], references: [leaveId])
  leaveDates      LeaveDate[]
}

model LeaveDate {
  leaveDateId     Int           @id @default(autoincrement())
  startDate       DateTime
  endDate         DateTime
  hoursOff        Float
  employeeLeaveId Int
  employeeLeave   EmployeeLeave @relation(fields: [employeeLeaveId], references: [employeeLeaveId])
  status          String        @default("Pending")
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum ProjectStatus {
  ACTIVE
  INACTIVE
}
